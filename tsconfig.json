{
  "compilerOptions": {
    "jsx": "react",
    "jsxFactory": "figma.widget.h",
    "jsxFragmentFactory": "figma.widget.Fragment",
    "target": "es6",
    "lib": ["es2016"],
    "strict": true,
    "moduleResolution": "bundler",
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/@figma"
    ]
  },
  "include": ["widget-src/**/*.tsx", "widget-src/**/*.ts"]
}
